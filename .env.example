# ============================================================
# BTOB Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# ============================================================

# --- Django ---
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=.rawaaj.com,localhost,127.0.0.1

# --- Multi-Tenant ---
PLATFORM_DOMAIN=rawaaj.com

# --- Database (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=btob_db
DB_USER=btob_user
DB_PASSWORD=your-secure-password-here
DB_HOST=db
DB_PORT=5432

# --- Google OAuth (Allauth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
